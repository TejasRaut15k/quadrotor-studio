<?xml version="1.0"?>
<robot name="quadrotor_drone">
  <material name="carbon">
    <color rgba="0.18 0.18 0.20 1.0"/>
  </material>
  <material name="accent_red">
    <color rgba="0.78 0.12 0.12 1.0"/>
  </material>
  <material name="silver">
    <color rgba="0.80 0.82 0.85 1.0"/>
  </material>
  <material name="magenta">
    <color rgba="0.85 0.20 0.75 1.0"/>
  </material>

  <link name="world"/>
  <link name="x_stage"/>
  <link name="y_stage"/>
  <link name="z_stage"/>
  <link name="yaw_stage"/>
  <link name="pitch_stage"/>
  <link name="base_link">
    <visual>
      <origin xyz="0 0 0" rpy="0 0 0"/>
      <geometry>
        <box size="0.18 0.12 0.04"/>
      </geometry>
      <material name="accent_red"/>
    </visual>
    <visual>
      <origin xyz="0 0 0.03" rpy="0 0 0"/>
      <geometry>
        <cylinder radius="0.02" length="0.08"/>
      </geometry>
      <material name="carbon"/>
    </visual>
    <visual>
      <origin xyz="0 0 0" rpy="0 1.57079632679 0"/>
      <geometry>
        <cylinder radius="0.012" length="0.44"/>
      </geometry>
      <material name="carbon"/>
    </visual>
    <visual>
      <origin xyz="0 0 0" rpy="1.57079632679 0 0"/>
      <geometry>
        <cylinder radius="0.012" length="0.44"/>
      </geometry>
      <material name="carbon"/>
    </visual>

    <visual>
      <origin xyz="0.22 0 0.015" rpy="0 0 0"/>
      <geometry>
        <cylinder radius="0.07" length="0.015"/>
      </geometry>
      <material name="silver"/>
    </visual>
    <visual>
      <origin xyz="-0.22 0 0.015" rpy="0 0 0"/>
      <geometry>
        <cylinder radius="0.07" length="0.015"/>
      </geometry>
      <material name="silver"/>
    </visual>
    <visual>
      <origin xyz="0 0.22 0.015" rpy="0 0 0"/>
      <geometry>
        <cylinder radius="0.07" length="0.015"/>
      </geometry>
      <material name="magenta"/>
    </visual>
    <visual>
      <origin xyz="0 -0.22 0.015" rpy="0 0 0"/>
      <geometry>
        <cylinder radius="0.07" length="0.015"/>
      </geometry>
      <material name="magenta"/>
    </visual>
  </link>

  <joint name="x_joint" type="prismatic">
    <parent link="world"/>
    <child link="x_stage"/>
    <origin xyz="0 0 0" rpy="0 0 0"/>
    <axis xyz="1 0 0"/>
    <limit lower="-5.0" upper="5.0" effort="500.0" velocity="5.0"/>
  </joint>

  <joint name="y_joint" type="prismatic">
    <parent link="x_stage"/>
    <child link="y_stage"/>
    <origin xyz="0 0 0" rpy="0 0 0"/>
    <axis xyz="0 1 0"/>
    <limit lower="-5.0" upper="5.0" effort="500.0" velocity="5.0"/>
  </joint>

  <joint name="z_joint" type="prismatic">
    <parent link="y_stage"/>
    <child link="z_stage"/>
    <origin xyz="0 0 0" rpy="0 0 0"/>
    <axis xyz="0 0 1"/>
    <limit lower="0.0" upper="10.0" effort="500.0" velocity="5.0"/>
  </joint>

  <joint name="yaw_joint" type="continuous">
    <parent link="z_stage"/>
    <child link="yaw_stage"/>
    <origin xyz="0 0 0" rpy="0 0 0"/>
    <axis xyz="0 0 1"/>
  </joint>

  <joint name="pitch_joint" type="continuous">
    <parent link="yaw_stage"/>
    <child link="pitch_stage"/>
    <origin xyz="0 0 0" rpy="0 0 0"/>
    <axis xyz="0 1 0"/>
  </joint>

  <joint name="roll_joint" type="continuous">
    <parent link="pitch_stage"/>
    <child link="base_link"/>
    <origin xyz="0 0 0" rpy="0 0 0"/>
    <axis xyz="1 0 0"/>
  </joint>
</robot>
